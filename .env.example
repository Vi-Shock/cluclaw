# === Bot Identity ===
BOT_NAME=CluClaw

# === Channel Configuration ===
WHATSAPP_ENABLED=false
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=          # from @BotFather — disable privacy mode in group settings

# === LLM Configuration ===
# Supported providers: openai | anthropic | groq | google | ollama | mistral
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=                 # API key for the provider (not needed for Ollama)
LLM_BASE_URL=                # Required for Ollama: http://localhost:11434/api

# === Vision Model (for receipt photos) ===
# Defaults to LLM_PROVIDER/LLM_MODEL if not set (must support vision)
VISION_PROVIDER=
VISION_MODEL=
VISION_API_KEY=              # Defaults to LLM_API_KEY

# === Speech-to-Text (for voice notes) ===
# Supported providers: groq | openai | local
STT_PROVIDER=groq
STT_MODEL=whisper-large-v3
STT_API_KEY=                 # Defaults to LLM_API_KEY

# === General ===
LOG_LEVEL=info               # debug | info | warn | error
DATA_DIR=./data              # Where SQLite databases are stored
DEFAULT_CURRENCY=INR         # Fallback when no currency symbol detected
DEFAULT_TIMEZONE=Asia/Kolkata

# === History ===
HISTORY_LIMIT=50             # How many recent messages to load into context
